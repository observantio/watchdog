{
  "schemaVersion": 38,
  "title": "Loki Log Insights",
  "timezone": "browser",
  "refresh": "30s",
  "uid": "loki-log-insights",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Error Logs / min",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} |= \"error\" [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Warning Logs / min",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\".+\"} |= \"warn\" [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent Errors",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\"} |= \"error\"",
          "refId": "A"
        }
      ]
    }
  ]
}
