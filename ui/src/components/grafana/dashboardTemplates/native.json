{
  "schemaVersion": 38,
  "title": "Complete System & Process Observability",
  "timezone": "browser",
  "refresh": "30s",
  "uid": "sys-proc-all",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Process CPU Usage (cores)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [{ "expr": "sum by(instance) (rate(process_cpu_time_seconds_total[$__rate_interval]))", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Process Disk I/O",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 1, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [{ "expr": "sum by(instance, direction) (rate(process_disk_io_bytes_total[$__rate_interval]))", "legendFormat": "{{instance}} · {{direction}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Process Memory (RSS)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 7 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 1, "fillOpacity": 8, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [{ "expr": "sum by(instance) (process_memory_usage_bytes)", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Process Memory (Virtual)",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 7 },
