      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 7 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 1, "fillOpacity": 8, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "mean"] }
      },
      "targets": [{ "expr": "sum by(instance, state) (rate(system_cpu_time_seconds_total[$__rate_interval])) / ignoring(state) group_left sum by(instance) (rate(system_cpu_time_seconds_total[$__rate_interval]))", "legendFormat": "{{instance}} · {{state}}", "refId": "A" }]
    },
