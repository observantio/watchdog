{
  "schemaVersion": 38,
  "title": "System & Process Metrics (Mimir)",
  "timezone": "browser",
  "refresh": "30s",
  "uid": "system-process-mimir",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Busy %",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Load Average (5m)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "node_load5",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Read Throughput",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_disk_read_bytes_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Write Throughput",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_disk_written_bytes_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Receive",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_receive_bytes_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Transmit",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "mimir-prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by(instance) (rate(node_network_transmit_bytes_total[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
