{
  "name": "beobservant-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docker": "docker compose up --build ui",
    "build": "vite build",
    "start": "vite preview --port 5173",
    "build:analyze": "ANALYZE=true vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest --run",
    "lint:css": "stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "lint:js": "eslint \"src/**/*.{js,jsx}\"",
    "lint": "npm run lint:css && npm run lint:js",
    "a11y": "vitest -t a11y"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.3",
    "clsx": "^1.2.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "react-window": "^1.8.11",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.8.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^5.8.0",
    "stylelint": "^15.11.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwind-scrollbar": "^2.0.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
