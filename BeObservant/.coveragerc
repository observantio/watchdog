[run]
branch = True
omit =
    tests/*
    */__init__.py
    middleware/dependencies.py
    middleware/request_size_limit.py
    middleware/audit.py
    middleware/resilience.py
    middleware/rate_limit/hybrid.py
    middleware/rate_limit/ip.py
    routers/access/auth_router/*.py
    routers/observability/becertain_router.py
    routers/observability/grafana_router/*.py
    models/access/api_key_models.py
    services/alerts/helpers.py
    services/auth/*.py
    services/benotified_proxy_service.py
    services/becertain_proxy_service.py
    services/common/cookies.py
    services/database_auth/*.py
    services/database_auth_service.py
    services/grafana/*.py
    services/grafana_proxy_service.py
    services/internal_service.py
    services/loki_service.py
    services/notification_service.py
    services/proxy/base_proxy.py
    services/secrets/provider.py
    services/secrets/vault_client.py
    services/common/ttl_cache.py
    services/tempo/parsers.py
    services/tempo/promql.py
    services/tempo_service.py

[report]
exclude_also =
    if TYPE_CHECKING:
