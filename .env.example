# .env.example — minimal & complete server envs
# ESSENTIALS: set DATABASE_URL, DEFAULT_ADMIN_PASSWORD, and JWT_PRIVATE_KEY/JWT_PUBLIC_KEY (for RS256) or JWT_SECRET_KEY (for HS256).

# --- Postgres (or provide DATABASE_URL) ---
POSTGRES_USER=beobservant
POSTGRES_PASSWORD=changeme
POSTGRES_DB=beobservant
POSTGRES_INITDB_ARGS="--encoding=UTF8 --lc-collate=C --lc-ctype=C"
# DATABASE_URL=postgresql://beobservant:changeme@postgres:5432/beobservant

# --- Server / app ---
HOST=0.0.0.0
PORT=4319
LOG_LEVEL=info

# JWT / session
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MINUTES=1440
JWT_SECRET_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Admin bootstrap
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_TENANT=default
DEFAULT_ORG_ID=default

# Encryption / tokens
DATA_ENCRYPTION_KEY=
DEFAULT_OTLP_TOKEN=

# CORS / proxy
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY_HEADERS=false
VITE_OIDC_PROVIDER_LABEL=Microsoft SSO / Keycloak

# --- Service endpoints (optional overrides) ---
TEMPO_URL=http://tempo:3200
LOKI_URL=http://loki:3100
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://grafana:3000
MIMIR_URL=http://mimir:9009
OTLP_GATEWAY_URL=http://otlp-gateway:4320

# --- Limits & rate limiting ---
MAX_REQUEST_BYTES=1048576
MAX_CONCURRENT_REQUESTS=200
CONCURRENCY_ACQUIRE_TIMEOUT=1.0
MAX_QUERY_LIMIT=5000
DEFAULT_QUERY_LIMIT=100
RATE_LIMIT_USER_PER_MINUTE=600
RATE_LIMIT_PUBLIC_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=5
RATE_LIMIT_GRAFANA_PROXY_PER_MINUTE=3000

# --- Auth / OIDC (optional) ---
AUTH_PROVIDER=local
AUTH_PASSWORD_FLOW_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_SCOPES=openid profile email
OIDC_AUTO_PROVISION_USERS=true
KEYCLOAK_ADMIN_URL=
KEYCLOAK_ADMIN_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_USER_PROVISIONING_ENABLED=false

# --- Webhooks / tokens ---
INBOUND_WEBHOOK_TOKEN=
OTLP_INGEST_TOKEN=
AGENT_HEARTBEAT_TOKEN=
OTEL_OTLP_TOKEN=

# --- Notifications / Email (optional) ---
ENABLED_NOTIFICATION_CHANNEL_TYPES=email,slack,teams,webhook,pagerduty
USER_WELCOME_EMAIL_ENABLED=false
USER_WELCOME_SMTP_HOST=
USER_WELCOME_SMTP_PORT=587
USER_WELCOME_SMTP_USERNAME=
USER_WELCOME_SMTP_PASSWORD=
USER_WELCOME_FROM=
USER_WELCOME_SMTP_STARTTLS=true
USER_WELCOME_SMTP_USE_SSL=false
INCIDENT_ASSIGNMENT_EMAIL_ENABLED=false
INCIDENT_ASSIGNMENT_SMTP_HOST=
INCIDENT_ASSIGNMENT_SMTP_PORT=587
INCIDENT_ASSIGNMENT_SMTP_USERNAME=
INCIDENT_ASSIGNMENT_SMTP_PASSWORD=
INCIDENT_ASSIGNMENT_FROM=
INCIDENT_ASSIGNMENT_SMTP_STARTTLS=true
INCIDENT_ASSIGNMENT_SMTP_USE_SSL=false

# --- Grafana runtime / provisioning (optional) ---
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin
GRAFANA_API_KEY=
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_INSTALL_PLUGINS=
MIMIR_TENANT_ID=your_org_id
GF_SERVER_ROOT_URL=http://localhost:8080/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_AUTH_PROXY_ENABLED=true
GF_AUTH_PROXY_HEADER_NAME=X-WEBAUTH-USER
GF_AUTH_PROXY_AUTO_SIGN_UP=true
GF_AUTH_PROXY_HEADERS=Email:X-WEBAUTH-EMAIL Name:X-WEBAUTH-NAME Role:X-WEBAUTH-ROLE
GF_AUTH_PROXY_WHITELIST=127.0.0.1,::1
GF_AUTH_ANONYMOUS_ENABLED=false
GF_AUTH_BASIC_ENABLED=true
GF_SECURITY_ALLOW_EMBEDDING=true

# --- Backups / S3 (optional) ---
BACKUP_ENABLED=false
S3_BUCKET=beobservant-backup
S3_PREFIX=metrics
BACKUP_INTERVAL=3600
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Networking / allowlists (optional) ---
AUTH_PUBLIC_IP_ALLOWLIST=
GATEWAY_IP_ALLOWLIST=
WEBHOOK_IP_ALLOWLIST=
GRAFANA_PROXY_IP_ALLOWLIST=

# --- Gateway-auth (optional) ---
GATEWAY_PORT=4321
GATEWAY_RATE_LIMIT_PER_MINUTE=300

# --- Misc ---
APP_LOGIN_URL=
DEFAULT_RULE_GROUP=default
DEFAULT_SLACK_CHANNEL=default

