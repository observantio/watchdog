# Core
APP_ENV=development
ENVIRONMENT=development
HOST=0.0.0.0
PORT=4319
LOG_LEVEL=info

# Postgres
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=watchdog
POSTGRES_INITDB_ARGS="--encoding=UTF8 --lc-collate=C --lc-ctype=C"
DATABASE_URL=postgresql://watchdog:changeme@postgres:5432/watchdog
NOTIFIER_DATABASE_URL=postgresql://watchdog:changeme@postgres:5432/watchdog_notified
DB_AUTO_CREATE_SCHEMA=true

# Auth / JWT
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MINUTES=1440
JWT_SECRET_KEY=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_AUTO_GENERATE_KEYS=true

# Bootstrap / tenancy
DEFAULT_ADMIN_BOOTSTRAP_ENABLED=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_please
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_TENANT=default
DEFAULT_ORG_ID=default
DEFAULT_OTLP_TOKEN=

# Service URLs
TEMPO_URL=http://tempo:3200
LOKI_URL=http://loki:3100
MIMIR_URL=http://mimir:9009
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://grafana:3000
NOTIFIER_URL=http://notifier:4323
RESOLVER_URL=http://resolver:4322
OTLP_GATEWAY_URL=http://otlp-gateway:4320

# Notifier proxy/auth
NOTIFIER_SERVICE_TOKEN=replace_with_strong_token
NOTIFIER_EXPECTED_SERVICE_TOKEN=replace_with_strong_token
NOTIFIER_CONTEXT_SIGNING_KEY=replace_with_strong_key
NOTIFIER_CONTEXT_VERIFY_KEY=replace_with_strong_key
NOTIFIER_CONTEXT_ISSUER=watchdog-main
NOTIFIER_CONTEXT_AUDIENCE=notifier
NOTIFIER_CONTEXT_ALGORITHM=HS256
NOTIFIER_CONTEXT_ALGORITHMS=HS256
NOTIFIER_CONTEXT_TTL_SECONDS=90
NOTIFIER_TIMEOUT_SECONDS=15
NOTIFIER_TLS_ENABLED=false
NOTIFIER_CA_CERT_PATH=

# Resolver proxy/auth (watchdog -> Resolver)
RESOLVER_SERVICE_TOKEN=replace_with_strong_token
RESOLVER_EXPECTED_SERVICE_TOKEN=replace_with_strong_token
RESOLVER_CONTEXT_SIGNING_KEY=replace_with_strong_key
RESOLVER_CONTEXT_VERIFY_KEY=replace_with_strong_key
RESOLVER_CONTEXT_ISSUER=watchdog-main
RESOLVER_CONTEXT_AUDIENCE=resolver
RESOLVER_CONTEXT_ALGORITHM=HS256
RESOLVER_CONTEXT_ALGORITHMS=HS256
RESOLVER_CONTEXT_TTL_SECONDS=120
RESOLVER_TIMEOUT_SECONDS=20
RESOLVER_TLS_ENABLED=false
RESOLVER_CA_CERT_PATH=
RESOLVER_DATABASE_URL=postgresql://watchdog:changeme@postgres:5432/watchdog_resolver
RESOLVER_ANALYZE_MAX_CONCURRENCY=2
RESOLVER_ANALYZE_TIMEOUT_SECONDS=90
RESOLVER_ANALYZE_REPORT_RETENTION_DAYS=7
RESOLVER_ANALYZE_JOB_TTL_DAYS=30
RESOLVER_DB_POOL_SIZE=10
RESOLVER_DB_MAX_OVERFLOW=20
RESOLVER_DB_POOL_TIMEOUT=30
RESOLVER_DB_POOL_RECYCLE=1800

# Resolver RCA/quality tuning (production-friendly defaults)
RESOLVER_CORRELATION_WINDOW_SECONDS=45
RESOLVER_ANALYZER_FETCH_TIMEOUT_SECONDS=10
RESOLVER_ANALYZER_METRICS_TIMEOUT_SECONDS=15
RESOLVER_ANALYZER_CAUSAL_TIMEOUT_SECONDS=6
RESOLVER_QUALITY_GATING_PROFILE=precision_strict_v1
RESOLVER_QUALITY_MAX_ANOMALY_DENSITY_PER_METRIC_PER_HOUR=0.75
RESOLVER_QUALITY_MAX_CHANGE_POINT_DENSITY_PER_METRIC_PER_HOUR=2.0
RESOLVER_QUALITY_MIN_CORROBORATION_SIGNALS=2
RESOLVER_QUALITY_MAX_ROOT_CAUSES_WITHOUT_MULTISIGNAL=1
RESOLVER_RCA_EVENT_CONFIDENCE_THRESHOLD=0.3
RESOLVER_RCA_MIN_CONFIDENCE_DISPLAY=0.12

# Resolver inbound TLS (optional, disabled by default)
RESOLVER_SSL_ENABLED=false
RESOLVER_SSL_CERTFILE=
RESOLVER_SSL_KEYFILE=

# Gateway auth service
GATEWAY_PORT=4321
GATEWAY_AUTH_API_URL=http://watchdog:4319/api/internal/otlp/validate
GATEWAY_INTERNAL_SERVICE_TOKEN=replace_with_strong_token
GATEWAY_STATUS_OTLP_TOKEN=
GATEWAY_IP_ALLOWLIST=
GATEWAY_ALLOWLIST_FAIL_OPEN=false
GATEWAY_RATE_LIMIT_PER_MINUTE=30000
GATEWAY_RATE_LIMIT_BACKEND=auto
GATEWAY_RATE_LIMIT_REDIS_URL=redis://redis:6379/1
GATEWAY_RATE_LIMIT_STRICT=false

# TTL cache and token cache
TTL_CACHE_REDIS_URL=
TTL_CACHE_KEY_PREFIX=beobs:ttl
GATEWAY_TOKEN_CACHE_REDIS_URL=redis://redis:6379/1
GATEWAY_TOKEN_CACHE_TTL=60
GATEWAY_SSL_VERIFY=true
GATEWAY_SSL_CA_CERTS=
GATEWAY_SSL_KEYFILE=
GATEWAY_SSL_CERTFILE=
GATEWAY_STARTUP_RETRIES=10
GATEWAY_STARTUP_BACKOFF=1.0
GATEWAY_DB_STARTUP_RETRIES=10
GATEWAY_DB_STARTUP_BACKOFF=1.0

# Security / boundary
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=
FORCE_SECURE_COOKIES=false
ALLOWLIST_FAIL_OPEN=false
REQUIRE_CLIENT_IP_FOR_PUBLIC_ENDPOINTS=false
AUTH_PUBLIC_IP_ALLOWLIST=
WEBHOOK_IP_ALLOWLIST=
GRAFANA_PROXY_IP_ALLOWLIST=
AGENT_INGEST_IP_ALLOWLIST=
AGENT_HEARTBEAT_TOKEN=

# Inbound tokens
INBOUND_WEBHOOK_TOKEN=replace_with_strong_webhook_token
OTLP_INGEST_TOKEN=
OTEL_OTLP_TOKEN=

# HTTP / resilience
DEFAULT_TIMEOUT=30.0
MAX_RETRIES=3
RETRY_BACKOFF=1.0
RETRY_MAX_BACKOFF=8.0
RETRY_JITTER=0.1
HTTP_CLIENT_MAX_CONNECTIONS=100
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=40
HTTP_CLIENT_KEEPALIVE_EXPIRY=30
SERVICE_CACHE_TTL_SECONDS=30

# Limits
MAX_REQUEST_BYTES=1048576
MAX_CONCURRENT_REQUESTS=200
CONCURRENCY_ACQUIRE_TIMEOUT=1.0
MAX_QUERY_LIMIT=1000
DEFAULT_QUERY_LIMIT=20
RATE_LIMIT_USER_PER_MINUTE=600
RATE_LIMIT_PUBLIC_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=5
RATE_LIMIT_GRAFANA_PROXY_PER_MINUTE=3000
RATE_LIMIT_GC_EVERY=1024
RATE_LIMIT_STALE_AFTER_SECONDS=3600
RATE_LIMIT_MAX_STATES=200000
RATE_LIMIT_FALLBACK_MODE=memory
PASSWORD_HASH_MAX_CONCURRENCY=8

# Local password lifecycle (applies only to auth_provider=local)
PASSWORD_RESET_INTERVAL_DAYS=0
TEMP_PASSWORD_LENGTH=20

# Tempo/Loki tuning
TEMPO_USE_METRICS_FOR_COUNT=true
TEMPO_TRACE_FETCH_CONCURRENCY=8
TEMPO_VOLUME_BUCKET_CONCURRENCY=8
LOKI_FALLBACK_CONCURRENCY=4
LOKI_MAX_FALLBACK_QUERIES=4

# OIDC / Keycloak
AUTH_PROVIDER=local | oidc | keycloak
AUTH_PASSWORD_FLOW_ENABLED=false | true
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_SCOPES=openid profile email
OIDC_AUTO_PROVISION_USERS=true

SKIP_LOCAL_MFA_FOR_EXTERNAL=true
KEYCLOAK_ADMIN_URL=
KEYCLOAK_ADMIN_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_USER_PROVISIONING_ENABLED=false

# Encryption / TOTP
DATA_ENCRYPTION_KEY=
REQUIRE_TOTP_ENCRYPTION_KEY=false

# Alerting / notifications
DEFAULT_RULE_GROUP=default
DEFAULT_SLACK_CHANNEL=default
ENABLED_NOTIFICATION_CHANNEL_TYPES=email,slack,teams,webhook,pagerduty

# Email settings for main server and notifications
USER_WELCOME_EMAIL_ENABLED=false
USER_WELCOME_SMTP_HOST=
USER_WELCOME_SMTP_PORT=587
USER_WELCOME_SMTP_USERNAME=
USER_WELCOME_SMTP_PASSWORD=
USER_WELCOME_FROM=
USER_WELCOME_SMTP_STARTTLS=true
USER_WELCOME_SMTP_USE_SSL=false
PASSWORD_RESET_EMAIL_ENABLED=false
PASSWORD_RESET_SMTP_HOST=
PASSWORD_RESET_SMTP_PORT=587
PASSWORD_RESET_SMTP_USERNAME=
PASSWORD_RESET_SMTP_PASSWORD=
PASSWORD_RESET_FROM=
PASSWORD_RESET_SMTP_STARTTLS=true
PASSWORD_RESET_SMTP_USE_SSL=false
INCIDENT_ASSIGNMENT_EMAIL_ENABLED=false
INCIDENT_ASSIGNMENT_SMTP_HOST=
INCIDENT_ASSIGNMENT_SMTP_PORT=587
INCIDENT_ASSIGNMENT_SMTP_USERNAME=
INCIDENT_ASSIGNMENT_SMTP_PASSWORD=
INCIDENT_ASSIGNMENT_FROM=
INCIDENT_ASSIGNMENT_SMTP_STARTTLS=true
INCIDENT_ASSIGNMENT_SMTP_USE_SSL=false
APP_LOGIN_URL=

# Grafana runtime
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin
GRAFANA_API_KEY=
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_INSTALL_PLUGINS=
MIMIR_TENANT_ID=default
MIMIR_CONFIG_FILE=./configs/mimir.yaml

# Mimir S3 mode 
MIMIR_S3_BUCKET=mimir-blocks
MIMIR_S3_ENDPOINT=s3.amazonaws.com
MIMIR_S3_REGION=us-east-1
MIMIR_S3_ACCESS_KEY=
MIMIR_S3_SECRET_KEY=
MIMIR_S3_FORCEPATHSTYLE=true
MIMIR_S3_INSECURE=false
GF_SERVER_ROOT_URL=http://localhost:8080/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_AUTH_PROXY_ENABLED=true
GF_AUTH_PROXY_HEADER_NAME=X-WEBAUTH-USER
GF_AUTH_PROXY_AUTO_SIGN_UP=true
GF_AUTH_PROXY_HEADERS=Email:X-WEBAUTH-EMAIL Name:X-WEBAUTH-NAME Role:X-WEBAUTH-ROLE
GF_AUTH_PROXY_WHITELIST=127.0.0.1,::1
GF_AUTH_ANONYMOUS_ENABLED=false
GF_AUTH_BASIC_ENABLED=true
GF_SECURITY_ALLOW_EMBEDDING=true

# Backup / cloud
BACKUP_ENABLED=false
S3_BUCKET=watchdog-backup
S3_PREFIX=metrics
BACKUP_INTERVAL=3600
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vault
VAULT_ENABLED=false
VAULT_ADDR=
VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_CACERT=
VAULT_SECRETS_PREFIX=secret
VAULT_KV_VERSION=2
VAULT_TIMEOUT=2.0
VAULT_FAIL_ON_MISSING=false

# UI
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
VITE_OTLP_GATEWAY_HOST=http://localhost:4320
VITE_OIDC_PROVIDER_LABEL=Microsoft SSO / Keycloak
